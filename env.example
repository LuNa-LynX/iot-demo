# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:151115@localhost:5432/cleanroom_db

# MQTT Configuration
MQTT_BROKER=localhost
MQTT_PORT=1883
# For subscriptions (mqtt_gateway): use wildcards like cleanroom/sensors/#
# For publishing (sensor_simulator): use specific topics like cleanroom/sensors/Room-1/Device-1
MQTT_TOPIC=cleanroom/sensors/#
MQTT_USERNAME=
MQTT_PASSWORD=

# Polling Configuration (seconds between database polls)
POLL_INTERVAL=2.0

# Replay Mode - Set to "true" to continuously replay existing data (useful for demos)
REPLAY_MODE=false
REPLAY_INTERVAL=5.0

# CSV Data Streaming (for synthetic data)
STREAM_INTERVAL=5.0
SHUFFLE_DATA=false
LOOP_DATA=true

# Alert Thresholds
ALERT_TEMP_MIN=18
ALERT_TEMP_MAX=25
ALERT_HUMIDITY_MIN=40
ALERT_HUMIDITY_MAX=60
ALERT_PRESSURE_MIN=8
ALERT_PRESSURE_MAX=20
ALERT_PARTICLE_LIMIT=300

# Cloud Backup Configuration
# NOTE: Cloud backup works GREAT with LOCAL storage (FREE, no account needed)
# Cloud providers (AWS/Azure) are OPTIONAL and require paid accounts
BACKUP_ENABLED=true
BACKUP_SCHEDULE=daily
BACKUP_TIME=02:00
BACKUP_RETENTION_DAYS=30
# Cloud provider: "local" (FREE), "aws" (PAID), "azure" (PAID)
CLOUD_PROVIDER=local
# AWS credentials only needed if CLOUD_PROVIDER=aws
AWS_S3_BUCKET=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
BACKUP_ENCRYPTION_KEY=
BACKUP_DIR=./backups

# Security Configuration
SECRET_KEY=
ENCRYPTION_ENABLED=true
INTEGRITY_CHECKS_ENABLED=true
